---
import { getLangFromUrl, useTranslations, localizeUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- How it works -->
<section class="py-16 px-4" style="border-top: 1px solid var(--color-border);">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 style="font-size: 2rem; font-weight: 700; color: var(--color-text-heading); margin-bottom: 0.75rem;">
        {t('howItWorks.title')}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      {[
        {
          step: '01',
          title: t('howItWorks.step1.title'),
          description: t('howItWorks.step1.description'),
          link: { text: lang === 'ja' ? 'キーを取得 →' : 'Get your key →', href: 'https://tcgpricelookup.com/pricing' },
        },
        {
          step: '02',
          title: t('howItWorks.step2.title'),
          description: t('howItWorks.step2.description'),
          link: null,
        },
        {
          step: '03',
          title: t('howItWorks.step3.title'),
          description: t('howItWorks.step3.description'),
          link: null,
        },
      ].map(item => (
        <div class="relative">
          <div style="font-family: var(--font-family-mono); font-size: 3rem; font-weight: 700; color: var(--color-border); margin-bottom: 0.75rem; line-height: 1;">
            {item.step}
          </div>
          <h3 style="color: var(--color-text-heading); font-weight: 600; font-size: 1.125rem; margin-bottom: 0.5rem;">
            {item.title}
          </h3>
          <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.6; margin-bottom: 0.75rem;">
            {item.description}
          </p>
          {item.link && (
            <a
              href={item.link.href}
              target="_blank"
              rel="noopener noreferrer"
              style="color: var(--color-accent); font-size: 0.875rem; text-decoration: none; font-weight: 500;"
            >
              {item.link.text}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Deploy section -->
<section class="py-16 px-4" style="border-top: 1px solid var(--color-border);">
  <div class="max-w-3xl mx-auto text-center">
    <h2 style="font-size: 2rem; font-weight: 700; color: var(--color-text-heading); margin-bottom: 0.75rem;">
      {t('deploy.title')}
    </h2>
    <p style="color: var(--color-text-muted); font-size: 1rem; margin-bottom: 2rem;">
      {t('deploy.description')}
    </p>

    <div class="flex flex-wrap justify-center gap-4 mb-8">
      <a
        href="https://deploy.workers.cloudflare.com/?url=https://github.com/TCG-Price-Lookup/tcgvault"
        target="_blank"
        rel="noopener noreferrer"
        style="background-color: #f48120; color: #fff; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 8px;"
        class="hover:opacity-90 transition-opacity"
      >
        Deploy to Cloudflare Pages
      </a>

      <a
        href="https://vercel.com/new/clone?repository-url=https://github.com/TCG-Price-Lookup/tcgvault"
        target="_blank"
        rel="noopener noreferrer"
        style="background-color: #000; color: #fff; border: 1px solid #333; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 8px;"
        class="hover:border-white transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 22.525H0l12-21.05 12 21.05z"/></svg>
        Deploy to Vercel
      </a>

      <a
        href="https://app.netlify.com/start/deploy?repository=https://github.com/TCG-Price-Lookup/tcgvault"
        target="_blank"
        rel="noopener noreferrer"
        style="background-color: #00ad9f; color: #fff; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 8px;"
        class="hover:opacity-90 transition-opacity"
      >
        Deploy to Netlify
      </a>
    </div>

    <div style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 10px; padding: 1.25rem; display: inline-block; text-align: left;">
      <div style="font-family: var(--font-family-mono); font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.25rem;"># Run locally</div>
      <div style="font-family: var(--font-family-mono); font-size: 0.875rem; color: var(--color-text);">git clone https://github.com/TCG-Price-Lookup/tcgvault</div>
      <div style="font-family: var(--font-family-mono); font-size: 0.875rem; color: var(--color-text);">cd tcgvault && cp .env.example .env</div>
      <div style="font-family: var(--font-family-mono); font-size: 0.875rem; color: var(--color-text-muted);"># Add TCG_API_KEY to .env</div>
      <div style="font-family: var(--font-family-mono); font-size: 0.875rem; color: var(--color-text);">npm install && npm run dev</div>
    </div>
  </div>
</section>

<!-- FAQ section -->
<section class="py-16 px-4" style="border-top: 1px solid var(--color-border);">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10">
      <h2 style="font-size: 2rem; font-weight: 700; color: var(--color-text-heading);">
        {t('faq.title')}
      </h2>
    </div>

    <div class="flex flex-col gap-4">
      {[
        { q: t('faq.q1'), a: t('faq.a1') },
        { q: t('faq.q2'), a: t('faq.a2') },
        { q: t('faq.q3'), a: t('faq.a3') },
        { q: t('faq.q4'), a: t('faq.a4') },
        { q: t('faq.q5'), a: t('faq.a5') },
        { q: t('faq.q6'), a: t('faq.a6') },
      ].map(item => (
        <details
          style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 10px; padding: 1.25rem;"
          class="group"
        >
          <summary style="color: var(--color-text-heading); font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;">
            {item.q}
            <svg style="color: var(--color-text-muted); flex-shrink: 0; margin-left: 1rem;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.7; margin-top: 0.75rem; margin-bottom: 0;">
            {item.a}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- Final CTA -->
<section class="py-20 px-4" style="border-top: 1px solid var(--color-border);">
  <div class="max-w-2xl mx-auto text-center">
    <h2 style="font-size: 2.25rem; font-weight: 700; color: var(--color-text-heading); margin-bottom: 1rem;">
      {t('cta.title')}
    </h2>
    <p style="color: var(--color-text-muted); font-size: 1rem; margin-bottom: 2rem;">
      {t('cta.description')}
    </p>
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem;">
      <a
        href={localizeUrl('/app', lang)}
        style="background-color: var(--color-accent); color: #000; font-weight: 700; font-size: 1.125rem; padding: 14px 32px; border-radius: 8px; text-decoration: none; display: inline-block;"
        class="transition-opacity hover:opacity-90"
      >
        {t('cta.getStarted')}
      </a>
      <a
        href="https://github.com/TCG-Price-Lookup/tcgvault"
        target="_blank"
        rel="noopener noreferrer"
        style="background-color: var(--color-bg-card); color: var(--color-text); border: 1px solid var(--color-border); font-weight: 600; font-size: 1.125rem; padding: 14px 32px; border-radius: 8px; text-decoration: none; display: inline-block;"
        class="transition-colors hover:border-white"
      >
        {t('footer.github')}
      </a>
    </div>
  </div>
</section>
