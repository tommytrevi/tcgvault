---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  {
    icon: '🎮',
    title: t('features.multiGame.title'),
    description: t('features.multiGame.description'),
  },
  {
    icon: '📈',
    title: t('features.livePricing.title'),
    description: t('features.livePricing.description'),
  },
  {
    icon: '🔒',
    title: t('features.envConfig.title'),
    description: t('features.envConfig.description'),
  },
  {
    icon: '📤',
    title: t('features.exportAnywhere.title'),
    description: t('features.exportAnywhere.description'),
  },
  {
    icon: '🚀',
    title: t('features.selfHostable.title'),
    description: t('features.selfHostable.description'),
  },
  {
    icon: '⚡',
    title: t('features.openSource.title'),
    description: t('features.openSource.description'),
  },
];
---

<section class="py-16 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <h2 style="font-size: 2rem; font-weight: 700; color: var(--color-text-heading); margin-bottom: 0.75rem;">
        {t('features.title')}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map(feature => (
        <div
          style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.5rem;"
          class="hover:border-opacity-60 transition-colors"
        >
          <div style="font-size: 1.75rem; margin-bottom: 0.75rem;" role="img">{feature.icon}</div>
          <h3 style="color: var(--color-text-heading); font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
            {feature.title}
          </h3>
          <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.6;">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
