---
import { getLangFromUrl, useTranslations, localizeUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer style="border-top: 1px solid var(--color-border); margin-top: 6rem;" class="py-10">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div>
        <div style="font-family: var(--font-family-mono); color: var(--color-accent); font-weight: 600; margin-bottom: 0.75rem;">
          tcgvault
        </div>
        <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.6;">
          {t('footer.tagline')}
        </p>
      </div>

      <div>
        <div style="color: var(--color-text-heading); font-weight: 600; font-size: 0.875rem; margin-bottom: 0.75rem;">
          App
        </div>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          <li><a href={localizeUrl('/app', lang)} style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">{t('nav.app')}</a></li>
          <li><a href={localizeUrl('/about', lang)} style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">{t('nav.about')}</a></li>
          <li><a href="https://github.com/TCG-Price-Lookup/tcgvault" target="_blank" rel="noopener noreferrer" style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">{t('footer.github')}</a></li>
        </ul>
      </div>

      <div>
        <div style="color: var(--color-text-heading); font-weight: 600; font-size: 0.875rem; margin-bottom: 0.75rem;">
          API & {t('footer.docs')}
        </div>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          <li><a href="https://tcgpricelookup.com/pricing" target="_blank" rel="noopener" style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">Get API Key</a></li>
          <li><a href="https://tcgfast.com/docs/" target="_blank" rel="noopener" style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">{t('footer.docs')}</a></li>
          <li><a href="https://tcgfast.com/docs/sdks/javascript/" target="_blank" rel="noopener" style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">JS SDK Reference</a></li>
        </ul>
      </div>

      <div>
        <div style="color: var(--color-text-heading); font-weight: 600; font-size: 0.875rem; margin-bottom: 0.75rem;">
          Related Projects
        </div>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          <li><a href="https://tcgfast.com" target="_blank" rel="noopener" style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">tcgfast.com</a></li>
          <li><a href="https://github.com/TCG-Price-Lookup" target="_blank" rel="noopener" style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">More Tools</a></li>
          <li><a href="https://tcgpricelookup.com" target="_blank" rel="noopener" style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none;" class="hover:text-white">TCG Price Lookup</a></li>
        </ul>
      </div>
    </div>

    <div style="border-top: 1px solid var(--color-border); padding-top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; align-items: center; text-align: center;">
      <p style="color: var(--color-text-muted); font-size: 0.8rem;">
        {t('footer.builtWith')} <a href="https://tcgpricelookup.com" target="_blank" rel="noopener" style="color: var(--color-accent); text-decoration: none;">{t('footer.api')}</a>
        &nbsp;·&nbsp;
        <a href="https://tcgfast.com" target="_blank" rel="noopener" style="color: var(--color-text-muted); text-decoration: none;" class="hover:text-white">{t('footer.docs')}</a>
        &nbsp;·&nbsp;
        <a href="https://github.com/TCG-Price-Lookup" target="_blank" rel="noopener" style="color: var(--color-text-muted); text-decoration: none;" class="hover:text-white">{t('footer.github')}</a>
      </p>
      <p style="color: var(--color-text-muted); font-size: 0.75rem;">
        {t('footer.license')} · Open Source · Zero Backend
      </p>
    </div>
  </div>
</footer>
