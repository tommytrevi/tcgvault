---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About TCGVault — How it Works"
  description="How TCGVault works. Server-rendered, API key in .env, collection stored in localStorage."
>
  <div style="max-width: 48rem; margin: 0 auto; padding: 3rem 1rem;">
    <!-- Heading -->
    <div style="margin-bottom: 3rem;">
      <div style="font-family: var(--font-family-mono); color: var(--color-accent); font-size: 0.8rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">
        About
      </div>
      <h1 style="font-size: 2.5rem; font-weight: 700; color: var(--color-text-heading); margin-bottom: 1rem; line-height: 1.2;">
        How TCGVault Works
      </h1>
      <p style="color: var(--color-text-muted); font-size: 1.05rem; line-height: 1.7;">
        TCGVault is a self-hostable TCG collection tracker. You deploy it with your API key set as an environment variable — the key lives on the server, never in the browser. Your collection is stored in your browser's localStorage.
      </p>
    </div>

    <!-- Architecture -->
    <section style="margin-bottom: 3rem;">
      <h2 style="color: var(--color-text-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
        Architecture
      </h2>

      <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.5rem;">
        {[
          {
            title: 'Hybrid Astro 5 App',
            description: 'TCGVault uses Astro\'s hybrid output mode. Landing pages are pre-rendered static HTML. API routes (/api/*) are server-rendered and run on Cloudflare Pages (or Node/Vercel/Netlify).',
          },
          {
            title: 'Server-side API Routes',
            description: 'All card price data is fetched server-side via Astro API routes. The SDK is called server-side only — never in the browser. API routes read TCG_API_KEY from the server environment.',
          },
          {
            title: 'localStorage for Collection',
            description: 'Your collection (card names, quantities, conditions, cached prices) is stored in your browser\'s localStorage under the "tcgvault:" namespace. No network request is made to save it.',
          },
          {
            title: 'Secure by Default',
            description: 'Your API key is set via .env on the server or in your deployment platform\'s environment variables. It is never exposed in the client bundle, never sent to the browser, never stored in localStorage.',
          },
        ].map(item => (
          <div style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 10px; padding: 1.25rem;">
            <h3 style="color: var(--color-accent); font-weight: 600; font-size: 0.95rem; margin-bottom: 0.5rem; font-family: var(--font-family-mono);">
              {item.title}
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.6; margin: 0;">
              {item.description}
            </p>
          </div>
        ))}
      </div>

      <!-- Data flow diagram -->
      <div style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 10px; padding: 1.5rem; font-family: var(--font-family-mono); font-size: 0.8rem;">
        <div style="color: var(--color-text-muted); margin-bottom: 0.75rem;">Data flow:</div>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <div style="color: var(--color-text);">
            <span style="color: var(--color-accent);">Your Browser</span>
            <span style="color: var(--color-text-muted);"> → localStorage (collection only)</span>
          </div>
          <div style="color: var(--color-text);">
            <span style="color: var(--color-accent);">Your Browser</span>
            <span style="color: var(--color-text-muted);"> → /api/search (your TCGVault server)</span>
          </div>
          <div style="color: var(--color-text);">
            <span style="color: var(--color-accent);">TCGVault Server</span>
            <span style="color: var(--color-text-muted);"> → tcgpricelookup.com (with TCG_API_KEY from env)</span>
          </div>
          <div style="color: var(--color-text-muted); border-top: 1px solid var(--color-border); margin-top: 0.5rem; padding-top: 0.5rem;">
            API key in browser: <span style="color: var(--color-accent);">never</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section style="margin-bottom: 3rem;">
      <h2 style="color: var(--color-text-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
        Tech Stack
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.75rem;">
        {[
          { name: 'Astro 5', role: 'Hybrid SSR framework' },
          { name: '@astrojs/cloudflare', role: 'Cloudflare Pages adapter' },
          { name: 'React 19', role: 'Interactive islands' },
          { name: 'Tailwind CSS 4', role: 'Styling' },
          { name: '@tcgpricelookup/sdk', role: 'Price data API (server-side)' },
          { name: 'TypeScript (strict)', role: 'Type safety' },
          { name: 'localStorage', role: 'Collection persistence' },
        ].map(item => (
          <div style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 8px; padding: 0.875rem;">
            <div style="color: var(--color-text-heading); font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem; font-family: var(--font-family-mono);">
              {item.name}
            </div>
            <div style="color: var(--color-text-muted); font-size: 0.78rem;">{item.role}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Privacy -->
    <section style="margin-bottom: 3rem;">
      <h2 style="color: var(--color-text-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
        Privacy
      </h2>
      <div style="background-color: rgba(0, 255, 136, 0.05); border: 1px solid rgba(0, 255, 136, 0.2); border-radius: 10px; padding: 1.25rem;">
        <ul style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.8; margin: 0; padding-left: 1.25rem;">
          <li>No account or login required</li>
          <li>No analytics or tracking scripts</li>
          <li>Your API key is stored only in server environment variables — never in the browser</li>
          <li>Your collection data is stored in your browser's localStorage</li>
          <li>Card price requests go from your server to tcgpricelookup.com — your key is never exposed client-side</li>
          <li>You own the deployment — you control where the data goes</li>
        </ul>
      </div>
    </section>

    <!-- Get API Key -->
    <section style="margin-bottom: 3rem;">
      <h2 style="color: var(--color-text-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
        Getting an API Key
      </h2>
      <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.7; margin-bottom: 1rem;">
        TCGVault uses the <a href="https://tcgpricelookup.com" target="_blank" rel="noopener" style="color: var(--color-accent); text-decoration: none;">TCG Price Lookup API</a>
        to fetch real-time card prices. You need a free API key, which you set as <code style="font-family: var(--font-family-mono); color: var(--color-accent); font-size: 0.85rem;">TCG_API_KEY</code> in your .env or deployment settings.
      </p>
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        <a href="https://tcgpricelookup.com/pricing" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px; color: var(--color-accent); text-decoration: none; font-size: 0.9rem; font-weight: 500;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Get a free API key at tcgpricelookup.com/pricing
        </a>
        <a href="https://tcgfast.com/docs/getting-started/" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px; color: var(--color-accent); text-decoration: none; font-size: 0.9rem; font-weight: 500;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Setup guide at tcgfast.com/docs/getting-started/
        </a>
      </div>
    </section>

    <!-- CTA -->
    <div style="text-align: center; padding: 2.5rem; background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 12px;">
      <h2 style="color: var(--color-text-heading); font-weight: 700; font-size: 1.5rem; margin-bottom: 0.75rem;">
        Ready to track your collection?
      </h2>
      <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;">
        Free, open source. Own your deployment.
      </p>
      <a
        href="/app"
        style="background-color: var(--color-accent); color: #000; font-weight: 700; font-size: 1rem; padding: 12px 28px; border-radius: 8px; text-decoration: none; display: inline-block;"
      >
        Launch TCGVault
      </a>
    </div>
  </div>
</BaseLayout>
