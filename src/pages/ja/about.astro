---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="tcgvaultについて — 仕組み"
  description="tcgvaultの仕組みについて。サーバーレンダリング、.envにAPIキー、コレクションはlocalStorageに保存。"
>
  <div style="max-width: 48rem; margin: 0 auto; padding: 3rem 1rem;">
    <!-- Heading -->
    <div style="margin-bottom: 3rem;">
      <div style="font-family: var(--font-family-mono); color: var(--color-accent); font-size: 0.8rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">
        このツールについて
      </div>
      <h1 style="font-size: 2.5rem; font-weight: 700; color: var(--color-text-heading); margin-bottom: 1rem; line-height: 1.2;">
        tcgvaultの仕組み
      </h1>
      <p style="color: var(--color-text-muted); font-size: 1.05rem; line-height: 1.7;">
        tcgvaultはセルフホスト対応のTCGコレクション追跡ツールです。APIキーを環境変数として設定してデプロイします。キーはサーバーに存在し、ブラウザには公開されません。コレクションはブラウザのlocalStorageに保存されます。
      </p>
    </div>

    <!-- Architecture -->
    <section style="margin-bottom: 3rem;">
      <h2 style="color: var(--color-text-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
        アーキテクチャ
      </h2>

      <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.5rem;">
        {[
          {
            title: 'ハイブリッドAstro 5アプリ',
            description: 'tcgvaultはAstroのハイブリッド出力モードを使用しています。ランディングページはプリレンダリングされた静的HTMLです。APIルート（/api/*）はサーバーレンダリングされ、Cloudflare Pages（またはNode/Vercel/Netlify）で動作します。',
          },
          {
            title: 'サーバーサイドAPIルート',
            description: 'カード価格データはすべてAstro APIルート経由でサーバーサイドで取得されます。SDKはサーバーサイドのみで呼び出され、ブラウザでは決して使用されません。APIルートはサーバー環境からTCG_API_KEYを読み込みます。',
          },
          {
            title: 'コレクションのlocalStorage保存',
            description: 'コレクション（カード名、数量、コンディション、キャッシュされた価格）はブラウザのlocalStorageに「tcgvault:」名前空間で保存されます。保存時にネットワークリクエストは発生しません。',
          },
          {
            title: 'デフォルトでセキュア',
            description: 'APIキーはサーバーの.envまたはデプロイプラットフォームの環境変数で設定します。クライアントバンドルには含まれず、ブラウザに送信されることも、localStorageに保存されることもありません。',
          },
        ].map(item => (
          <div style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 10px; padding: 1.25rem;">
            <h3 style="color: var(--color-accent); font-weight: 600; font-size: 0.95rem; margin-bottom: 0.5rem; font-family: var(--font-family-mono);">
              {item.title}
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.6; margin: 0;">
              {item.description}
            </p>
          </div>
        ))}
      </div>

      <!-- Data flow diagram -->
      <div style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 10px; padding: 1.5rem; font-family: var(--font-family-mono); font-size: 0.8rem;">
        <div style="color: var(--color-text-muted); margin-bottom: 0.75rem;">データフロー:</div>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <div style="color: var(--color-text);">
            <span style="color: var(--color-accent);">ブラウザ</span>
            <span style="color: var(--color-text-muted);"> → localStorage（コレクションのみ）</span>
          </div>
          <div style="color: var(--color-text);">
            <span style="color: var(--color-accent);">ブラウザ</span>
            <span style="color: var(--color-text-muted);"> → /api/search（tcgvaultサーバー）</span>
          </div>
          <div style="color: var(--color-text);">
            <span style="color: var(--color-accent);">tcgvaultサーバー</span>
            <span style="color: var(--color-text-muted);"> → tcgpricelookup.com（環境変数のTCG_API_KEYを使用）</span>
          </div>
          <div style="color: var(--color-text-muted); border-top: 1px solid var(--color-border); margin-top: 0.5rem; padding-top: 0.5rem;">
            ブラウザ上のAPIキー: <span style="color: var(--color-accent);">なし</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section style="margin-bottom: 3rem;">
      <h2 style="color: var(--color-text-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
        テックスタック
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.75rem;">
        {[
          { name: 'Astro 5', role: 'ハイブリッドSSRフレームワーク' },
          { name: '@astrojs/cloudflare', role: 'Cloudflare Pagesアダプター' },
          { name: 'React 19', role: 'インタラクティブアイランド' },
          { name: 'Tailwind CSS 4', role: 'スタイリング' },
          { name: '@tcgpricelookup/sdk', role: '価格データAPI（サーバーサイド）' },
          { name: 'TypeScript (strict)', role: '型安全性' },
          { name: 'localStorage', role: 'コレクション永続化' },
        ].map(item => (
          <div style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 8px; padding: 0.875rem;">
            <div style="color: var(--color-text-heading); font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem; font-family: var(--font-family-mono);">
              {item.name}
            </div>
            <div style="color: var(--color-text-muted); font-size: 0.78rem;">{item.role}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Privacy -->
    <section style="margin-bottom: 3rem;">
      <h2 style="color: var(--color-text-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
        プライバシー
      </h2>
      <div style="background-color: rgba(0, 255, 136, 0.05); border: 1px solid rgba(0, 255, 136, 0.2); border-radius: 10px; padding: 1.25rem;">
        <ul style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.8; margin: 0; padding-left: 1.25rem;">
          <li>アカウントやログイン不要</li>
          <li>アナリティクスやトラッキングスクリプトなし</li>
          <li>APIキーはサーバー環境変数にのみ保存 — ブラウザには公開されません</li>
          <li>コレクションデータはブラウザのlocalStorageに保存</li>
          <li>カード価格リクエストはサーバーからtcgpricelookup.comへ — キーはクライアントサイドに公開されません</li>
          <li>デプロイを自分でコントロール — データの行き先を管理できます</li>
        </ul>
      </div>
    </section>

    <!-- Get API Key -->
    <section style="margin-bottom: 3rem;">
      <h2 style="color: var(--color-text-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
        APIキーの取得
      </h2>
      <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.7; margin-bottom: 1rem;">
        tcgvaultは <a href="https://tcgpricelookup.com" target="_blank" rel="noopener" style="color: var(--color-accent); text-decoration: none;">TCG Price Lookup API</a>
        を使ってリアルタイムのカード価格を取得します。無料のAPIキーが必要で、.envまたはデプロイ設定に <code style="font-family: var(--font-family-mono); color: var(--color-accent); font-size: 0.85rem;">TCG_API_KEY</code> として設定します。
      </p>
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        <a href="https://tcgpricelookup.com/pricing" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px; color: var(--color-accent); text-decoration: none; font-size: 0.9rem; font-weight: 500;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          tcgpricelookup.com/pricingで無料APIキーを取得
        </a>
        <a href="https://tcgfast.com/docs/getting-started/" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px; color: var(--color-accent); text-decoration: none; font-size: 0.9rem; font-weight: 500;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          セットアップガイド: tcgfast.com/docs/getting-started/
        </a>
      </div>
    </section>

    <!-- CTA -->
    <div style="text-align: center; padding: 2.5rem; background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 12px;">
      <h2 style="color: var(--color-text-heading); font-weight: 700; font-size: 1.5rem; margin-bottom: 0.75rem;">
        コレクションを追跡する準備はできましたか？
      </h2>
      <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;">
        無料、オープンソース。自分でデプロイを管理。
      </p>
      <a
        href="/ja/app"
        style="background-color: var(--color-accent); color: #000; font-weight: 700; font-size: 1rem; padding: 12px 28px; border-radius: 8px; text-decoration: none; display: inline-block;"
      >
        アプリを起動
      </a>
    </div>
  </div>
</BaseLayout>
